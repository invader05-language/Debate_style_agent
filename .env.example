# Multi-AI Debate Agent Configuration

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/debate_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# MIMO API
MIMO_API_KEY=your_mimo_api_key_here
MIMO_API_URL=https://api.mimo.com/v1
MIMO_MODEL=mimo-7b

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# LangChain
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=false

# Debate settings
MAX_DEBATE_ROUNDS=3
DEBATE_TIMEOUT=300

# Execution settings
EXECUTION_TIMEOUT=30
EXECUTION_MEMORY_LIMIT=256m

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=1.0

# Application
DEBUG=false
LOG_LEVEL=INFO
