# Multi-AI Debate Agent Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/debate_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# MIMO API
MIMO_API_KEY=tp-sd9sdp4jifh1k8spazttcno3uc6ugqfux3672hkom6fk238m
MIMO_API_URL=https://token-plan-sgp.xiaomimimo.com/anthropic
MIMO_MODEL=mimo-v2.5-pro

# DeepSeek API
DEEPSEEK_API_KEY=sk-55ab30ccd5a94582a772e2cbded03623
DEEPSEEK_API_URL=https://api.deepseek.com/v4
DEEPSEEK_MODEL=deepseek-chat

# LangChain (optional)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false

# Debate settings
MAX_DEBATE_ROUNDS=3
DEBATE_TIMEOUT=300

# Execution settings
EXECUTION_TIMEOUT=30
EXECUTION_MEMORY_LIMIT=256m

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=1.0

# Application
DEBUG=false
LOG_LEVEL=INFO

# Backend (FastAPI)
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
WS_HEARTBEAT=30

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
